# Supabase (public keys — safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin auth (LEGACY — being phased out, see below)
# These NEXT_PUBLIC_* passwords ship in the client bundle and are public.
# Kept only for the transition window. Rotate + remove after cutover.
NEXT_PUBLIC_ADMIN_PASSWORD=your-password

# Server-side gate auth (audit C1/C3 remediation). Server-only, never
# NEXT_PUBLIC. The gate route /api/auth/gate validates a submitted
# password against these and sets a SIGNED httpOnly session cookie.
#   AUTH_SESSION_SECRET  long random string (e.g. `openssl rand -hex 32`)
#   ADMIN_PASSWORD / CRO_PASSWORD / TEAM_PASSWORD  the gate passwords
# After the client is fully on /api/auth/gate, set AUTH_LEGACY_COOKIE=off
# to stop honouring the forgeable legacy `launchpad-role` cookie.
AUTH_SESSION_SECRET=
ADMIN_PASSWORD=
CRO_PASSWORD=
TEAM_PASSWORD=
# AUTH_LEGACY_COOKIE=off

# Slack
# SLACK_TOKEN is a user token (xoxp-) used for read operations including
# search.messages (search:read scope). SLACK_BOT_TOKEN (xoxb-) is used by
# slack-bot.ts for posting messages. Felix's read tools prefer SLACK_TOKEN
# but fall back to SLACK_BOT_TOKEN if it's missing.
SLACK_TOKEN=xoxp-your-slack-token
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_DYLAN_USER_ID=
SLACK_AJAY_USER_ID=
SLACK_ALISTER_USER_ID=
SLACK_OPS_CHANNEL_ID=

# AI
ANTHROPIC_API_KEY=sk-ant-api03-your-key

# Cron auth — used by Vercel cron endpoints under /api/cron/*. For local
# manual testing of Felix's digest:
#   curl -H "Authorization: Bearer $CRON_SECRET" \
#     "http://localhost:3000/api/cron/felix-digest?dryRun=1"
CRON_SECRET=

# Proposals / Client Self-Serve
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_your-token
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret

# Email (optional)
RESEND_API_KEY=

# ── Sales dashboard messaging ─────────────────────────────────────
# Inbound webhook signing - generic fallback when not using Unipile.
# HMAC SHA256 over the raw body. Header: X-Webhook-Signature.
SALES_INBOUND_SECRET=

# Unipile (hosted bridge for Gmail / WhatsApp / LinkedIn / X / etc.)
# When all four UNIPILE_* base vars + at least one *_ACCOUNT_ID are
# set, the sales dashboard sends real messages through Unipile. With
# any missing, the channel falls back to stub-mode (logs + records
# the touch so the inbox still feels real).
#
# Provisioning:
#   1. Sign up at unipile.com, get API key + assigned DSN
#   2. Connect each account in their dashboard (Gmail OAuth, WhatsApp
#      QR scan, LinkedIn login) - copy each account ID into the
#      matching env var below
#   3. Configure inbound webhooks in Unipile to POST to
#      https://ecomlanders.app/api/sales/inbound/{channel}
#      with X-Unipile-Signature signed by UNIPILE_WEBHOOK_SECRET
UNIPILE_API_KEY=
UNIPILE_DSN=
UNIPILE_WEBHOOK_SECRET=
UNIPILE_EMAIL_ACCOUNT_ID=
UNIPILE_WHATSAPP_ACCOUNT_ID=
UNIPILE_LINKEDIN_ACCOUNT_ID=
UNIPILE_TWITTER_ACCOUNT_ID=
UNIPILE_INSTAGRAM_ACCOUNT_ID=
UNIPILE_TELEGRAM_ACCOUNT_ID=
