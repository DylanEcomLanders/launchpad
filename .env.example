# Supabase (public keys — safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin auth
NEXT_PUBLIC_ADMIN_PASSWORD=your-password

# Slack
# SLACK_TOKEN is a user token (xoxp-) used for read operations including
# search.messages (search:read scope). SLACK_BOT_TOKEN (xoxb-) is used by
# slack-bot.ts for posting messages. Felix's read tools prefer SLACK_TOKEN
# but fall back to SLACK_BOT_TOKEN if it's missing.
SLACK_TOKEN=xoxp-your-slack-token
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_DYLAN_USER_ID=
SLACK_AJAY_USER_ID=
SLACK_ALISTER_USER_ID=
SLACK_OPS_CHANNEL_ID=

# AI
ANTHROPIC_API_KEY=sk-ant-api03-your-key

# Cron auth — used by Vercel cron endpoints under /api/cron/*. For local
# manual testing of Felix's digest:
#   curl -H "Authorization: Bearer $CRON_SECRET" \
#     "http://localhost:3000/api/cron/felix-digest?dryRun=1"
CRON_SECRET=

# Proposals / Client Self-Serve
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_your-token
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret

# Email (optional)
RESEND_API_KEY=
